{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "cargo build --target wasm32-wasip2",
      "group": {
        "kind": "build",
        "isDefault": true,
      },
    },
    {
      "label": "Run (in NGINX)",
      "type": "shell",
      "command": "curl \"http://10.1.1.4:9000/services?name=more-body-mechanisms\" --data-binary \"@target/wasm32-wasip2/debug/more-body-mechanisms.wasm\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "dependsOn": ["Build"],
    },
    {
      "label": "Run (in BIG-IP)",
      "type": "shell",
      "command": "curl \"http://10.1.1.4:9001/services?name=more-body-mechanisms\" --data-binary \"@target/wasm32-wasip2/debug/more-body-mechanisms.wasm\"",
      "group": "test",
      "presentation": {
        "reveal": "always",
        "panel": "new"
      },
      "dependsOn": ["Build"],
    }
  ]
}
