{
  // See https://go.microsoft.com/fwlink/?LinkId=733558
  // for the documentation about the tasks.json format
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build",
      "type": "shell",
      "command": "../common/build.sh",
      "group": {
        "kind": "build",
        "isDefault": true,
      },
    },
    {
      "label": "Run in NGINX",
      "type": "shell",
      "command": "../common/run.sh --nginx",
      "group": "test",
      "dependsOn": ["Build"],
    },
    {
      "label": "Run in BIG-IP",
      "type": "shell",
      "command": "../common/run.sh --bigip",
      "group": "test",
      "dependsOn": ["Build"],
    }
  ]
}
